# Resend (transactional email — ROI report send)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Connectors <hey@email.getconnectors.ai>

# Meta Pixel + Conversions API
# Provision in Meta Business Manager → Events Manager.
# - NEXT_PUBLIC_META_PIXEL_ID: client-side pixel ID, fired in browser via fbevents.js.
# - META_PIXEL_ID: same value as NEXT_PUBLIC_META_PIXEL_ID, but readable from server routes for CAPI.
# - META_CAPI_ACCESS_TOKEN: long-lived CAPI token (Events Manager → Settings → Conversions API).
# - META_TEST_EVENT_CODE: optional; while set, CAPI events appear in Events Manager → Test Events.
#   REMOVE this line once verified, otherwise live events are tagged as test data.
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# META_TEST_EVENT_CODE=

# Cal.com webhook signing secret (BOOKING_CREATED → CAPI Schedule)
# Generate a strong random string, register the webhook in dot-connectors-llc.cal.com
# admin with the SAME secret. Cal HMAC-SHA256 signs each delivery as x-cal-signature-256.
CAL_WEBHOOK_SECRET=

# GA4 (optional, ignored if blank)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
